{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env DEBUG=app:* concurrently \"npm run dev:server\" \"npm run dev:client\"",
